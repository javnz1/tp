@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Package Model as ModelPackage <<Rectangle>>{
Class "<<interface>>\nReadOnlyAddressBook" as ReadOnlyAddressBook
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nModel" as Model
Class AddressBook
Class ModelManager
Class UserPrefs

Class UniquePersonList
Class Person
Class Address
Class Email
Class Name
Class Phone
Class Tag

Class UniqueEquipmentList
Class Equipment
Class EquipmentName
Class Category
Class EquipmentStatus

Class UniqueRoomList
Class Room
Class RoomName
Class Location
Class Status

Class I #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

ReadOnlyAddressBook -[hidden]right-> Model
Model -[hidden]right-> ReadOnlyUserPrefs

AddressBook .up.|> ReadOnlyAddressBook

ModelManager .up.|> Model
Model .right.> ReadOnlyUserPrefs
Model .left.> ReadOnlyAddressBook
ModelManager -left-> "1" AddressBook
ModelManager -right-> "1" UserPrefs
UserPrefs .up.|> ReadOnlyUserPrefs

AddressBook *--> "1" UniquePersonList
UniquePersonList --> "~* all" Person
Person *--> Name
Person *--> Phone
Person *--> Email
Person *--> Address
Person *--> "*" Tag

Person -[hidden]up--> I
UniquePersonList -[hidden]right-> I

Name -[hidden]right-> Phone
Phone -[hidden]right-> Address
Address -[hidden]right-> Email

ModelManager --> "~* filtered" Person

'---Equipment Section---'
AddressBook *--> "1" UniqueEquipmentList
UniqueEquipmentList --> "~* all" Equipment
Equipment *--> EquipmentName
Equipment *--> Category
Equipment *--> EquipmentStatus

Equipment -[hidden]up--> I
UniqueEquipmentList -[hidden]right-> I

EquipmentName -[hidden]right-> Category
Category -[hidden]right-> EquipmentStatus

ModelManager --> "~* filtered" Equipment

'---Room Section---'
AddressBook *--> "1" UniqueRoomList
UniqueRoomList --> "~* all" Room
Room *--> RoomName
Room *--> Location
Room *--> Status

Room -[hidden]up--> I
UniqueRoomList -[hidden]right-> I

RoomName -[hidden]right-> Location
Location -[hidden]right-> Status

ModelManager --> "~* filtered" Room
@enduml
